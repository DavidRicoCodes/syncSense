{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:sync:schema:v1:inventory",
  "title": "InventoryV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "inventory_id", "storage", "nodes"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "inventory_id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "root"],
      "properties": {
        "backend": {"enum": ["local", "nfs"]},
        "root": {"type": "string", "minLength": 1},
        "client_mount": {"type": "string", "minLength": 1}
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["node_id", "transport", "workspace", "commands"],
        "properties": {
          "node_id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
          "transport": {"enum": ["local", "ssh"]},
          "workspace": {"type": "string", "minLength": 1},
          "ssh": {
            "type": "object",
            "additionalProperties": false,
            "required": ["host"],
            "properties": {
              "host": {"type": "string", "minLength": 1},
              "user": {"type": "string", "minLength": 1},
              "port": {"type": "integer", "minimum": 1, "maximum": 65535},
              "identity_file": {"type": "string", "minLength": 1},
              "known_hosts_file": {"type": "string", "minLength": 1}
            }
          },
          "commands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["command_id", "argv", "safety_class"],
              "properties": {
                "command_id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
                "argv": {"type": "array", "minItems": 1, "items": {"type": "string"}},
                "cwd": {"type": "string", "minLength": 1},
                "env": {"type": "object", "additionalProperties": {"type": "string"}},
                "env_from": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$"}},
                "safety_class": {"enum": ["simulation", "infrastructure", "dsp", "rf"]}
              }
            }
          }
        },
        "allOf": [
          {"if": {"properties": {"transport": {"const": "ssh"}}}, "then": {"required": ["ssh"]}},
          {"if": {"properties": {"transport": {"const": "local"}}}, "then": {"not": {"required": ["ssh"]}}}
        ]
      }
    }
  }
}
