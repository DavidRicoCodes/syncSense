{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:sync:schema:v1:producer-manifest",
  "title": "ProducerManifestV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "producer_id", "role", "node_id", "status", "clock_domain_ids", "process", "artifacts", "event_summary"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "run_id": {"type": "string", "minLength": 1},
    "producer_id": {"type": "string", "minLength": 1},
    "role": {"enum": ["receiver", "transmitter"]},
    "node_id": {"type": "string", "minLength": 1},
    "status": {"const": "COMPLETE"},
    "clock_domain_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "process": {
      "type": "object", "additionalProperties": false,
      "required": ["backend", "started_at", "stopped_at", "exit_code", "termination_reason"],
      "properties": {
        "backend": {"type": "string"}, "started_at": {"type": "string", "format": "date-time"}, "stopped_at": {"type": "string", "format": "date-time"},
        "exit_code": {"type": "integer"}, "termination_reason": {"type": "string"}
      }
    },
    "artifacts": {"type": "array", "items": {"$ref": "artifact.schema.json"}},
    "event_summary": {
      "type": "object", "additionalProperties": false,
      "required": ["count", "by_clock_domain"],
      "properties": {
        "count": {"type": "integer", "minimum": 0},
        "by_clock_domain": {
          "type": "object",
          "additionalProperties": {
            "type": "object", "additionalProperties": false,
            "required": ["count", "first_ticks", "last_ticks", "tick_rate_hz"],
            "properties": {
              "count": {"type": "integer", "minimum": 1}, "first_ticks": {"type": "integer", "minimum": 0},
              "last_ticks": {"type": "integer", "minimum": 0}, "tick_rate_hz": {"type": "integer", "minimum": 1}
            }
          }
        }
      }
    }
  }
}

