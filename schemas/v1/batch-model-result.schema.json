{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:sync:schema:v1:batch-model-result",
  "title": "BatchModelResultV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "inference_id", "run_id", "status", "adapter", "started_at", "finished_at", "inputs", "outputs", "artifacts", "error"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "inference_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["SUCCEEDED", "FAILED"]},
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter_id", "adapter_version"],
      "properties": {
        "adapter_id": {"type": "string", "minLength": 1},
        "adapter_version": {"type": "string", "minLength": 1}
      }
    },
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "inputs": {"type": "array", "items": {"type": "string"}},
    "outputs": {"type": "array", "items": {"type": "string"}},
    "artifacts": {"type": "array", "items": {"$ref": "artifact.schema.json"}},
    "error": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": {"type": "string", "minLength": 1},
            "message": {"type": "string", "minLength": 1},
            "details": {"type": "object"}
          }
        }
      ]
    }
  }
}
